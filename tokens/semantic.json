{
  "color": {
    "base": {
      "primary": {
        "$extensions": {
          "com.figma.scopes": ["ALL_SCOPES"],
          "com.figma.hiddenFromPublishing": false
        },
        "$type": "color",
        "$value": "{color.charcoal.600}"
      },
      "secondary": {
        "$extensions": {
          "com.figma.scopes": ["ALL_SCOPES"],
          "com.figma.hiddenFromPublishing": false
        },
        "$type": "color",
        "$value": "{color.neutral.500}"
      },
      "foreground": {
        "$extensions": {
          "com.figma.scopes": ["ALL_SCOPES"],
          "com.figma.hiddenFromPublishing": false
        },
        "$type": "color",
        "$value": "{color.white}"
      },
      "destructive": {
        "$extensions": {
          "com.figma.scopes": ["ALL_SCOPES"],
          "com.figma.hiddenFromPublishing": false
        },
        "$type": "color",
        "$value": "{color.tomato.600}"
      },
      "mutedForeground": {
        "$extensions": {
          "com.figma.scopes": ["ALL_SCOPES"],
          "com.figma.hiddenFromPublishing": false
        },
        "$type": "color",
        "$value": "{color.charcoal.50}"
      },
      "brandNeutrals": {
        "$extensions": {
          "com.figma.scopes": ["ALL_SCOPES"],
          "com.figma.hiddenFromPublishing": false
        },
        "$type": "color",
        "$value": "{color.neutral.500}"
      }
    },
    "focus": {
      "ring": {
        "$extensions": {
          "com.figma.scopes": ["ALL_SCOPES"],
          "com.figma.hiddenFromPublishing": false
        },
        "$type": "color",
        "$value": "{color.neutral.200}"
      },
      "ring-error": {
        "$extensions": {
          "com.figma.scopes": ["ALL_SCOPES"],
          "com.figma.hiddenFromPublishing": false
        },
        "$type": "color",
        "$value": "{color.tomato.50}"
      }
    }
  },
  "space": {
    "3xs": { "$type": "dimension", "$value": "{spacing.0.5}" },
    "2xs": { "$type": "dimension", "$value": "{spacing.1}" },
    "xs": { "$type": "dimension", "$value": "{spacing.2}" },
    "sm": { "$type": "dimension", "$value": "{spacing.3}" },
    "md": { "$type": "dimension", "$value": "{spacing.4}" },
    "lg": { "$type": "dimension", "$value": "{spacing.5}" },
    "xl": { "$type": "dimension", "$value": "{spacing.6}" },
    "2xl": { "$type": "dimension", "$value": "{spacing.8}" },
    "3xl": { "$type": "dimension", "$value": "{spacing.10}" }
  },
  "rounded": {
    "none": { "$type": "dimension", "$value": "0px" },
    "sm": { "$type": "dimension", "$value": "{radius.4}" },
    "md": { "$type": "dimension", "$value": "{radius.6}" },
    "lg": { "$type": "dimension", "$value": "{radius.8}" },
    "full": { "$type": "dimension", "$value": "{radius.full}" }
  },
  "text": {
    "xs": { "$type": "dimension", "$value": "{font.size.xs}" },
    "sm": { "$type": "dimension", "$value": "{font.size.sm}" },
    "md": { "$type": "dimension", "$value": "{font.size.md}" },
    "lg": { "$type": "dimension", "$value": "{font.size.lg}" }
  },
  "leading": {
    "tight": { "$type": "dimension", "$value": "{font.lineHeight.tight}" },
    "normal": { "$type": "dimension", "$value": "{font.lineHeight.normal}" },
    "relaxed": { "$type": "dimension", "$value": "{font.lineHeight.relaxed}" }
  }
}
